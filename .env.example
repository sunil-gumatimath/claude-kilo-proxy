# claude-kilo-proxy environment variables
# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# Your Kilo Code API key (get it from https://kilo.ai)
# Optional if the client sends x-api-key / Authorization
KILO_API_KEY=your-kilo-api-key-here

# Upstream OpenAI-compatible base URL
# KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Bind address (default: 127.0.0.1 = localhost only)
# Use 0.0.0.0 only inside Docker / trusted networks
# PROXY_HOST=127.0.0.1

# Local proxy port
# PROXY_PORT=4181

# Model name prefix for the gateway
# MODEL_PREFIX=anthropic/

# Fallback model when the client omits "model"
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Upstream fetch timeout in milliseconds (default: 120000)
# UPSTREAM_TIMEOUT_MS=120000

# Max request body size in bytes (default: 20MB)
# MAX_BODY_BYTES=20971520

# Verbose debug logging with redaction (default: false)
# DEBUG=true
