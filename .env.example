# claude-kilo-proxy environment variables
# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# Your Kilo Code API key (get it from https://kilo.ai)
KILO_API_KEY=your-kilo-api-key-here

# Kilo Gateway base URL (default shown below)
# KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Local proxy port (default: 4181)
# PROXY_PORT=4181

# Model name prefix added when forwarding to Kilo (default: "anthropic/")
# e.g. "claude-sonnet-4-20250514" becomes "anthropic/claude-sonnet-4-20250514"
# MODEL_PREFIX=anthropic/

# Enable verbose debug logging (default: false)
# DEBUG=true
