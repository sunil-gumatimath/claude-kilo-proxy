# claude-kilo-proxy environment variables
# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# Your Kilo Code API key (get it from https://kilo.ai)
# Optional if the client sends x-api-key / Authorization
KILO_API_KEY=your-kilo-api-key-here

# Optional key required from clients before the proxy forwards a request.
# With this set, configure Claude Code's ANTHROPIC_AUTH_TOKEN to this value.
# PROXY_API_KEY=choose-a-long-random-secret

# Upstream OpenAI-compatible base URL
# KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Bind address (default: 127.0.0.1 = localhost only)
# Use 0.0.0.0 only inside Docker / trusted networks
# PROXY_HOST=127.0.0.1

# Local proxy port
# PROXY_PORT=4181

# Model name prefix for the gateway
# MODEL_PREFIX=anthropic/  # only if your gateway requires it

# Fallback model when the client omits "model"
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Automatically tried only when the requested model is rate-limited or the
# upstream has a temporary failure. Set to empty to disable fallback.
# FALLBACK_MODELS=nex-agi/nex-n2-pro:free,poolside/laguna-m.1:free

# Upstream fetch timeout in milliseconds (default: 120000)
# UPSTREAM_TIMEOUT_MS=120000

# Keep TLS certificate verification enabled. Set to false only for a trusted
# corporate proxy / local HTTPS inspection certificate that Bun cannot verify.
# UPSTREAM_TLS_REJECT_UNAUTHORIZED=false

# Preferred solution for a corporate HTTPS-inspection certificate: point to its
# PEM file and leave verification enabled.
# UPSTREAM_CA_FILE=C:\\certs\\corporate-root-ca.pem

# Route normal Claude model names to free Kilo models. Comma-separated
# pattern=model entries; * is supported in patterns.
# MODEL_ALIASES=claude-haiku*=inclusionai/ling-2.6-flash:free,claude-sonnet*=tencent/hy3:free,claude-opus*=poolside/laguna-m.1:free
# SMART_ROUTING=true

# Capacity protection plus per-model cooldown after 429/5xx failures.
# MAX_CONCURRENT_REQUESTS=4
# MAX_QUEUED_REQUESTS=20
# MODEL_COOLDOWN_MS=30000

# Max request body size in bytes (default: 20MB)
# MAX_BODY_BYTES=20971520

# Verbose debug logging with redaction (default: false)
# DEBUG=true

# Optional comma-separated browser origins permitted for CORS. Browser access is
# disabled by default; Claude Code does not need this.
# CORS_ALLOWED_ORIGINS=http://localhost:3000
